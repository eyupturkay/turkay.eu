---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import t from '../i18n/tr.json';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;

const links = [
  { href: '/tr/', label: t.nav.home },
  { href: '/tr/hizmetlerimiz', label: t.nav.services },
  { href: '/tr/cozumlerimiz', label: t.nav.solutions },
  { href: '/tr/projelerimiz', label: t.nav.projects },
  { href: '/tr/yazilar', label: t.nav.blog },
  { href: '/tr/iletisim', label: t.nav.contact },
];
---
<BaseLayout title={title} description={description} lang="tr" ogImage={ogImage} canonical={canonical}>
  <Nav lang="tr" links={links} />
  <main>
    <slot />
  </main>
  <Footer lang="tr" />
</BaseLayout>
