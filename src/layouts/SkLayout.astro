---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import t from '../i18n/sk.json';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;

const links = [
  { href: '/sk/', label: t.nav.home },
  { href: '/sk/sluzby', label: t.nav.services },
  { href: '/sk/projekty', label: t.nav.projects },
  { href: '/sk/blog', label: t.nav.blog },
  { href: '/sk/kontakt', label: t.nav.contact },
];
---
<BaseLayout title={title} description={description} lang="sk" ogImage={ogImage} canonical={canonical}>
  <Nav lang="sk" links={links} />
  <main>
    <slot />
  </main>
  <Footer lang="sk" />
</BaseLayout>
