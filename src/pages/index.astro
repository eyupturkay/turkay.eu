---
import EnLayout from '../layouts/EnLayout.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import BlogCard from '../components/BlogCard.astro';
import CTA from '../components/CTA.astro';
import { getCollection } from 'astro:content';
import en from '../i18n/en.json';

const services = (await getCollection('en-services')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const projects = (await getCollection('en-projects')).sort((a, b) => new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime()).slice(0, 3);
const testimonials = await getCollection('en-testimonials');
const blogs = (await getCollection('en-blog')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);

const stats = [
  { value: '43+', label: 'Projects Delivered' },
  { value: '15+', label: 'Enterprise Clients' },
  { value: '10+', label: 'Years Experience' },
  { value: '3', label: 'Global Offices' },
];
---
<EnLayout title="Integrated Digital Solutions" description="TURKAY provides AI, cloud, and software solutions for enterprises. Offices in Istanbul and Bratislava.">
  <Hero title="Building Intelligent Solutions for Tomorrow's Challenges" subtitle="We combine AI expertise, cloud engineering, and full-stack development to deliver technology that drives real business impact." ctaText={en.hero.cta} ctaHref="/contact" lang="en" />

  <Stats stats={stats} />

  <section class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-12">{en.sections.services}</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {services.map(s => <ServiceCard title={s.data.title} description={s.data.description} icon={s.data.icon} href="/services" />)}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-12">{en.sections.projects}</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {projects.map(p => <ProjectCard title={p.data.title} description={p.data.description} category={p.data.category} tags={p.data.tags} href={`/projects`} />)}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-12">{en.sections.testimonials}</h2>
    <div class="grid md:grid-cols-2 gap-8">
      {testimonials.map(t => <TestimonialCard name={t.data.name} role={t.data.role} company={t.data.company} content={t.body ?? ''} rating={t.data.rating} />)}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-12">{en.sections.blog}</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {blogs.map(b => <BlogCard title={b.data.title} description={b.data.description} date={b.data.date} author={b.data.author} category={b.data.category} readTime={b.data.readTime} href={`/blog/${b.id}`} />)}
    </div>
  </section>

  <CTA title="Ready to Transform Your Business?" description="Let's discuss how our AI, cloud, and development expertise can accelerate your digital transformation." buttonText={en.cta.contactUs} buttonHref="/contact" />
</EnLayout>
