---
import TrLayout from '../../../layouts/TrLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import tr from '../../../i18n/tr.json';

const blogs = (await getCollection('tr-blog')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<TrLayout title="Yazılar" description="TURKAY'dan yapay zeka, bulut bilişim ve yazılım geliştirme üzerine içgörüler.">
  <section class="max-w-7xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-bold text-center mb-4">{tr.sections.blog}</h1>
    <p class="text-center text-[#94a3b8] mb-16 max-w-2xl mx-auto">Ekibimizden içgörüler, eğitimler ve düşünce liderliği.</p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {blogs.map(b => (
        <BlogCard title={b.data.title} description={b.data.description} date={b.data.date} author={b.data.author} category={b.data.category} readTime={b.data.readTime} href={`/tr/yazilar/${b.id}`} />
      ))}
    </div>
  </section>
</TrLayout>
