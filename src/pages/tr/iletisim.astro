---
import TrLayout from '../../layouts/TrLayout.astro';
import tr from '../../i18n/tr.json';
---
<TrLayout title="İletişim" description="Eyüp Türkay ile iletişime geçin. Bratislava merkezli bağımsız yazılım danışmanı, 30 yıllık deneyim.">
  <section class="max-w-7xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-bold text-center mb-4 text-[#4AA9F5]">İletişim</h1>
    <p class="text-center text-[#94a3b8] mb-16 max-w-2xl mx-auto">Dijital dönüşümünüze başlamaya hazır mısınız? Ücretsiz 30 dakikalık strateji görüşmesi için benimle iletişime geçin.</p>

    <div class="grid lg:grid-cols-2 gap-16">
      <!-- İletişim Formu -->
      <div class="bg-[#111d33] border border-[#1e3a5f] rounded-2xl p-8">
        <h2 class="text-2xl font-bold text-[#e2e8f0] mb-6">Mesaj Gönderin</h2>
        <form class="space-y-6" id="contactForm">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm text-[#94a3b8] mb-2">Ad Soyad</label>
              <input type="text" required class="w-full px-4 py-3 bg-[#0a1628] border border-[#1e3a5f] rounded-lg text-[#e2e8f0] focus:border-[#FFBC42] focus:outline-none transition-colors" placeholder="Adınız" />
            </div>
            <div>
              <label class="block text-sm text-[#94a3b8] mb-2">E-posta</label>
              <input type="email" required class="w-full px-4 py-3 bg-[#0a1628] border border-[#1e3a5f] rounded-lg text-[#e2e8f0] focus:border-[#FFBC42] focus:outline-none transition-colors" placeholder="eposta@adresiniz.com" />
            </div>
          </div>
          <div>
            <label class="block text-sm text-[#94a3b8] mb-2">Konu</label>
            <input type="text" class="w-full px-4 py-3 bg-[#0a1628] border border-[#1e3a5f] rounded-lg text-[#e2e8f0] focus:border-[#FFBC42] focus:outline-none transition-colors" placeholder="Size nasıl yardımcı olabilirim?" />
          </div>
          <div>
            <label class="block text-sm text-[#94a3b8] mb-2">Bütçe Aralığı</label>
            <select class="w-full px-4 py-3 bg-[#0a1628] border border-[#1e3a5f] rounded-lg text-[#e2e8f0] focus:border-[#FFBC42] focus:outline-none transition-colors">
              <option value="">Seçiniz</option>
              <option value="500-">€500 altı</option>
              <option value="500-2000">€500 – €2.000</option>
              <option value="2000-5000">€2.000 – €5.000</option>
              <option value="5000+">€5.000+</option>
            </select>
          </div>
          <div>
            <label class="block text-sm text-[#94a3b8] mb-2">Bizi Nasıl Buldunuz?</label>
            <select class="w-full px-4 py-3 bg-[#0a1628] border border-[#1e3a5f] rounded-lg text-[#e2e8f0] focus:border-[#FFBC42] focus:outline-none transition-colors">
              <option value="">Seçiniz</option>
              <option value="google">Google</option>
              <option value="linkedin">LinkedIn</option>
              <option value="tavsiye">Tavsiye</option>
              <option value="diger">Diğer</option>
            </select>
          </div>
          <div>
            <label class="block text-sm text-[#94a3b8] mb-2">Mesaj</label>
            <textarea rows="5" class="w-full px-4 py-3 bg-[#0a1628] border border-[#1e3a5f] rounded-lg text-[#e2e8f0] focus:border-[#FFBC42] focus:outline-none transition-colors resize-none" placeholder="Projeniz hakkında bilgi verin..."></textarea>
          </div>
          <button type="button" onclick="alert('Mesajınız alındı! En kısa sürede size dönüş yapacağım.')" class="w-full px-6 py-3 bg-[#FFBC42] text-[#0a1628] font-semibold rounded-lg hover:bg-[#FFBC42]/90 transition-colors">Mesaj Gönder</button>
        </form>
      </div>

      <!-- İletişim Bilgileri -->
      <div class="space-y-8">
        <div>
          <h2 class="text-2xl font-bold text-[#e2e8f0] mb-6">İletişim Bilgilerim</h2>
          <p class="text-[#94a3b8] mb-8">E-posta, telefon veya WhatsApp ile bana ulaşabilirsiniz.</p>
        </div>

        <!-- WhatsApp CTA -->
        <a href="https://wa.me/421915455756" target="_blank" rel="noopener" class="block bg-green-600/20 border border-green-500/30 rounded-2xl p-8 hover:border-green-500/50 transition-colors">
          <div class="flex items-center gap-4">
            <svg class="w-10 h-10 text-green-400" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <div>
              <h3 class="text-xl font-bold text-green-400 mb-1">WhatsApp ile Yazın</h3>
              <p class="text-[#94a3b8]">+421 915 455 756 · Hızlı cevap</p>
            </div>
          </div>
        </a>

        <!-- Görüşme Planla -->
        <div class="bg-gradient-to-r from-[#FFBC42]/20 to-[#4AA9F5]/20 border border-[#1e3a5f]/30 rounded-2xl p-8">
          <h3 class="text-lg font-bold text-[#e2e8f0] mb-2">Ücretsiz Görüşme Planla</h3>
          <p class="text-[#94a3b8] mb-4">30 dakikalık ücretsiz strateji görüşmesi ile projenizi değerlendirelim.</p>
          <a href="mailto:info@turkay.eu?subject=Görüşme Talebi" class="inline-block px-6 py-3 bg-[#FFBC42] text-[#0a1628] font-semibold rounded-lg hover:bg-[#FFBC42]/90 transition-colors">
            Görüşme Talep Et
          </a>
        </div>

        <!-- Bratislava ofisi -->
        <div class="bg-[#111d33] border border-[#1e3a5f] rounded-2xl p-8">
          <h3 class="text-xl font-bold text-[#FFBC42] mb-4">Bratislava, Slovakya</h3>
          <div class="space-y-3 text-[#94a3b8]">
            <p class="flex items-start gap-3">
              <span class="text-[#29A8FF] mt-1">📍</span>
              <span>SKY PARK Offices, Bottova 7939/2A, 811 09 Bratislava</span>
            </p>
            <p class="flex items-center gap-3">
              <span class="text-[#29A8FF]">📞</span>
              <a href="tel:+421915455756" class="hover:text-[#FFBC42] transition-colors">+421 915 455 756</a>
            </p>
            <p class="flex items-center gap-3">
              <span class="text-[#29A8FF]">✉️</span>
              <a href="mailto:info@turkay.eu" class="hover:text-[#FFBC42] transition-colors">info@turkay.eu</a>
            </p>
          </div>
        </div>

        <!-- LinkedIn CTA -->
        <div class="bg-[#111d33] border border-[#1e3a5f] rounded-2xl p-8">
          <h3 class="text-lg font-bold text-[#e2e8f0] mb-2">LinkedIn'de Bağlanalım</h3>
          <p class="text-[#94a3b8] mb-4">Profesyonel ağımda yer alın.</p>
          <a href="https://linkedin.com/in/eyupturkay" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 bg-[#0077B5] text-white rounded-lg font-medium hover:bg-[#0077B5]/80 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn Profilim
          </a>
        </div>
      </div>
    </div>
  </section>
</TrLayout>
