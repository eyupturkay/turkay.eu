---
import TrLayout from '../../layouts/TrLayout.astro';
import Hero from '../../components/Hero.astro';
import Stats from '../../components/Stats.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import BlogCard from '../../components/BlogCard.astro';
import CTA from '../../components/CTA.astro';
import { getCollection } from 'astro:content';
import tr from '../../i18n/tr.json';

const services = (await getCollection('tr-services')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const projects = (await getCollection('tr-projects')).sort((a, b) => new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime()).slice(0, 3);
const testimonials = await getCollection('tr-testimonials');
const blogs = (await getCollection('tr-blog')).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);

const stats = [
  { value: '43+', label: 'Tamamlanan Proje' },
  { value: '15+', label: 'Kurumsal Müşteri' },
  { value: '10+', label: 'Yıllık Deneyim' },
  { value: '3', label: 'Global Ofis' },
];
---
<TrLayout title="Entegre Dijital Çözümler" description="TURKAY, işletmeler için yapay zeka, bulut ve yazılım çözümleri sunar. İstanbul ve Bratislava ofisleri.">
  <Hero title="Geleceğin Zorluklarına Akıllı Çözümler" subtitle="Yapay zeka uzmanlığı, bulut mühendisliği ve full-stack geliştirme ile gerçek iş etkisi yaratan teknolojiler sunuyoruz." ctaText={tr.hero.cta} ctaHref="/tr/iletisim" lang="tr" />

  <Stats stats={stats} />

  <section class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-12">{tr.sections.services}</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {services.map(s => <ServiceCard title={s.data.title} description={s.data.description} icon={s.data.icon} href="/tr/hizmetlerimiz" />)}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-12">{tr.sections.projects}</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {projects.map(p => <ProjectCard title={p.data.title} description={p.data.description} category={p.data.category} tags={p.data.tags} href="/tr/projelerimiz" />)}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-12">{tr.sections.testimonials}</h2>
    <div class="grid md:grid-cols-2 gap-8">
      {testimonials.map(t => <TestimonialCard name={t.data.name} role={t.data.role} company={t.data.company} content={t.body ?? ''} rating={t.data.rating} />)}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-20">
    <h2 class="text-3xl font-bold text-center mb-12">{tr.sections.blog}</h2>
    <div class="grid md:grid-cols-3 gap-8">
      {blogs.map(b => <BlogCard title={b.data.title} description={b.data.description} date={b.data.date} author={b.data.author} category={b.data.category} readTime={b.data.readTime} href={`/tr/yazilar/${b.id}`} />)}
    </div>
  </section>

  <CTA title="İşletmenizi Dönüştürmeye Hazır mısınız?" description="Yapay zeka, bulut ve geliştirme uzmanlığımızın dijital dönüşümünüzü nasıl hızlandırabileceğini konuşalım." buttonText={tr.cta.contactUs} buttonHref="/tr/iletisim" />
</TrLayout>
