---
import TrLayout from '../../layouts/TrLayout.astro';
import Hero from '../../components/Hero.astro';
import TargetAudience from '../../components/TargetAudience.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Pricing from '../../components/Pricing.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import CTA from '../../components/CTA.astro';
import FAQ from '../../components/FAQ.astro';
import { getCollection } from 'astro:content';
import tr from '../../i18n/tr.json';

const services = (await getCollection('tr-services')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const projects = (await getCollection('tr-projects')).sort((a, b) => new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime()).slice(0, 4);
const faqs = (await getCollection('tr-faq')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---
<TrLayout title="Yazılım, Otomasyon ve AI Çözümleri" description="Avrupa'daki Türk işletmeleri için yazılım, otomasyon ve AI çözümleri. Bratislava merkezli, 30 yıllık deneyim.">

  <!-- 1. Hero -->
  <Hero
    title={tr.hero.title}
    subtitle={tr.hero.subtitle}
    ctaText={tr.hero.cta}
    ctaHref="/tr/iletisim"
    secondaryCtaText={tr.hero.secondaryCta}
    secondaryCtaHref="/tr/hizmetlerimiz"
    badge={tr.hero.badge}
    lang="tr"
  />

  <!-- 2. Kimler İçin Çalışıyorum -->
  <TargetAudience lang="tr" />

  <!-- 3. Neden Beni Seçmelisiniz -->
  <WhyChooseUs lang="tr" />

  <!-- 4. Hizmetlerim -->
  <section id="hizmetlerimiz" class="py-16 bg-[#1A2B50]">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="section-heading text-center">{tr.sections.services}</h2>
      <p class="section-subheading text-center">{tr.sections.servicesSubtitle}</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map(s => (
          <ServiceCard
            title={s.data.title}
            description={s.data.description}
            icon={s.data.icon ?? '💻'}
            href="/tr/hizmetlerimiz"
            features={s.data.features}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Paketlerim -->
  <Pricing lang="tr" />

  <!-- 6. Projelerim -->
  <section id="projelerimiz" class="py-16 bg-[#1A2B50]">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="section-heading text-center">{tr.sections.projects}</h2>
      <p class="section-subheading text-center">{tr.sections.projectsSubtitle}</p>
      <div class="w-20 h-1 bg-[#29A8FF] mx-auto mb-10 rounded-full"></div>
      <div class="grid md:grid-cols-2 gap-6">
        {projects.map(p => (
          <ProjectCard
            title={p.data.title}
            description={p.data.description}
            category={p.data.category}
            tags={p.data.tags ?? []}
            href="/tr/projelerimiz"
            image={p.data.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- 7. SSS -->
  <section id="sss" class="py-16 bg-[#192749]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col md:flex-row gap-12">
        <div class="md:w-1/3">
          <div class="sticky top-24">
            <div class="text-5xl mb-4">❓</div>
            <h2 class="section-heading">{tr.sections.faq}</h2>
            <p class="text-white/80 mb-6">{tr.sections.faqSubtitle}</p>
            <a href="/tr/iletisim" class="inline-block px-6 py-3 bg-[#FFBC42] text-[#0a1628] font-bold rounded-lg hover:bg-[#FFBC42]/90 transition-colors">
              {tr.cta.contactUs}
            </a>
          </div>
        </div>
        <div class="md:w-2/3">
          <FAQ items={faqs.map(f => ({ question: f.data.question, answer: f.body ?? '' }))} />
        </div>
      </div>
    </div>
  </section>

  <!-- 8. CTA -->
  <CTA
    title="Dijital Dönüşümünüze Hazır mısınız?"
    description="30 yıllık deneyimimle, işletmenizin dijital dönüşümünü hızlı, güvenli ve uygun maliyetle gerçekleştirelim."
    buttonText={tr.cta.contactUs}
    buttonHref="/tr/iletisim"
  />

</TrLayout>
