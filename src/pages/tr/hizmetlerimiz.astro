---
import TrLayout from '../../layouts/TrLayout.astro';
import { getCollection, render } from 'astro:content';
import tr from '../../i18n/tr.json';

const services = (await getCollection('tr-services')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---
<TrLayout title="Hizmetlerim" description="Yapay zeka, bulut ve yazılım geliştirme hizmetlerimi keşfedin.">
  <section class="max-w-7xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-bold text-center mb-4 text-[#4AA9F5]">{tr.sections.services}</h1>
    <p class="text-center text-[#94a3b8] mb-16 max-w-2xl mx-auto">Dijital dönüşümünüzü hızlandıracak kapsamlı teknoloji hizmetleri.</p>

    <div class="space-y-12">
      {await Promise.all(services.map(async (service) => {
        const { Content } = await render(service);
        return (
          <div class="bg-[#192749] border border-[#0B3C5D]/30 rounded-2xl p-8 md:p-12 hover:border-[#FFBC42]/30 transition-colors duration-300">
            <div class="flex items-start gap-4 mb-6">
              {service.data.icon && <span class="text-4xl">{service.data.icon}</span>}
              <div>
                <h2 class="text-2xl font-bold text-[#FFBC42]">{service.data.title}</h2>
                <p class="text-white/90 mt-2">{service.data.description}</p>
              </div>
            </div>
            {service.data.features && (
              <ul class="grid md:grid-cols-2 gap-3 mb-8">
                {service.data.features.map((f: string) => (
                  <li class="flex items-center gap-2 text-white/80">
                    <span class="text-[#FFBC42]">•</span> {f}
                  </li>
                ))}
              </ul>
            )}
            <div class="prose prose-invert max-w-none text-[#94a3b8]">
              <Content />
            </div>
          </div>
        );
      }))}
    </div>
  </section>
</TrLayout>
