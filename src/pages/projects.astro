---
import EnLayout from '../layouts/EnLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import en from '../i18n/en.json';

const projects = (await getCollection('en-projects')).sort((a, b) => new Date(b.data.date ?? 0).getTime() - new Date(a.data.date ?? 0).getTime());
---
<EnLayout title="Our Projects" description="Explore TURKAY's portfolio of AI, cloud, and software projects.">
  <section class="max-w-7xl mx-auto px-4 py-20">
    <h1 class="text-4xl font-bold text-center mb-4">{en.sections.projects}</h1>
    <p class="text-center text-[#94a3b8] mb-16 max-w-2xl mx-auto">A selection of projects showcasing our expertise across industries.</p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map(p => (
        <ProjectCard title={p.data.title} description={p.data.description} category={p.data.category} tags={p.data.tags} href={`/projects`} />
      ))}
    </div>
  </section>
</EnLayout>
