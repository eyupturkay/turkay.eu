---
interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaHref: string;
  lang: 'en' | 'tr' | 'sk';
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const { title, subtitle, ctaText, ctaHref, lang, secondaryCtaText, secondaryCtaHref } = Astro.props;
---
<section class="relative overflow-hidden min-h-[85vh] flex items-center">
  <!-- Background with overlay -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2672&auto=format&fit=crop')] bg-cover bg-center bg-no-repeat"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#1A2B50] via-[#1A2B50]/70 to-[#1A2B50]/30"></div>
    <div class="absolute inset-0 bg-[radial-gradient(#1e3a5f_1px,transparent_1px)] [background-size:20px_20px] opacity-40"></div>
  </div>

  <!-- Gradient orbs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[#FFBC42]/10 rounded-full blur-[100px]"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-[#29A8FF]/10 rounded-full blur-[100px]"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full">
    <div class="max-w-4xl">
      <p class="text-[#FFBC42] text-lg md:text-xl mb-4 tracking-wider font-light">
        {lang === 'tr' ? 'Dijital Dönüşüm & Teknoloji' : lang === 'sk' ? 'Digitálna transformácia' : 'Digital Transformation & Technology'}
      </p>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold leading-tight tracking-tight text-white">
        {title}
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-gray-300 max-w-2xl leading-relaxed">
        {subtitle}
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-start gap-4">
        <a
          href={ctaHref}
          class="inline-block px-8 py-3.5 bg-[#FFBC42] text-[#1A2B50] font-semibold text-base rounded-lg hover:bg-[#FFBC42]/90 transition-colors duration-200 shadow-lg shadow-[#FFBC42]/20"
        >
          {ctaText}
        </a>
        {secondaryCtaText && secondaryCtaHref && (
          <a
            href={secondaryCtaHref}
            class="inline-block px-8 py-3.5 border border-[#FFBC42] text-[#FFBC42] font-semibold text-base rounded-lg hover:bg-[#FFBC42] hover:text-[#1A2B50] transition-all duration-200"
          >
            {secondaryCtaText}
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-float">
    <svg class="w-6 h-10 text-[#FFBC42]/60" fill="none" stroke="currentColor" viewBox="0 0 24 40">
      <rect x="1" y="1" width="22" height="38" rx="11" stroke-width="2"/>
      <circle cx="12" cy="12" r="3" fill="currentColor">
        <animate attributeName="cy" values="12;24;12" dur="2s" repeatCount="indefinite"/>
      </circle>
    </svg>
  </div>
</section>
