---
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: 'en' | 'tr' | 'sk';
  links: { href: string; label: string }[];
}

const { lang, links } = Astro.props;
const menuId = 'mobile-menu';
const currentPath = Astro.url.pathname;
---
<nav class="sticky top-0 z-50 bg-[#0a1628]/95 backdrop-blur-md border-b border-[#1e3a5f]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={lang === 'en' ? '/' : `/${lang}/`} class="flex items-center gap-2 group">
        <span class="inline-flex items-center justify-center w-9 h-9 bg-[#FFBC42] rounded-lg text-[#0a1628] font-extrabold text-lg">T</span>
        <span class="text-xl font-extrabold tracking-tight">
          <span class="text-[#FFBC42]">TURKAY</span><span class="text-[#29A8FF]">.EU</span>
        </span>
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-6">
        {links.map((link) => {
          const isActive = currentPath === link.href || currentPath === link.href + '/';
          return (
            <a
              href={link.href}
              class:list={[
                "text-sm font-medium transition-colors duration-200",
                isActive ? "text-[#FFBC42]" : "text-[#94a3b8] hover:text-[#e2e8f0]"
              ]}
            >
              {link.label}
            </a>
          );
        })}
        <LanguageSwitcher current={lang} />
      </div>

      <!-- Mobile hamburger -->
      <div class="md:hidden flex items-center gap-3">
        <LanguageSwitcher current={lang} />
        <label for={menuId} class="cursor-pointer p-2 text-[#e2e8f0]" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </label>
      </div>
    </div>
  </div>

  <input type="checkbox" id={menuId} class="hidden peer" />

  <div class="hidden peer-checked:block md:hidden border-t border-[#1e3a5f] bg-[#0a1628]">
    <div class="px-4 py-3 space-y-2">
      {links.map((link) => {
        const isActive = currentPath === link.href || currentPath === link.href + '/';
        return (
          <a
            href={link.href}
            class:list={[
              "block px-3 py-2 rounded text-sm font-medium transition-colors duration-200",
              isActive ? "text-[#FFBC42] bg-[#111d33]" : "text-[#94a3b8] hover:text-[#e2e8f0] hover:bg-[#111d33]"
            ]}
          >
            {link.label}
          </a>
        );
      })}
    </div>
  </div>
</nav>
