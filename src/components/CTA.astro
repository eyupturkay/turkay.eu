---
interface Props {
  title: string;
  description: string;
  buttonText: string;
  buttonHref: string;
}

const { title, description, buttonText, buttonHref } = Astro.props;
---
<section class="py-16 sm:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-[#f59e0b]/10 via-[#38bdf8]/10 to-[#f59e0b]/10 border border-[#1e3a5f] p-8 sm:p-12 lg:p-16 text-center">
      <!-- Gradient glow -->
      <div class="absolute inset-0 -z-10">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-[#f59e0b]/5 rounded-full blur-[100px]"></div>
      </div>

      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-[#e2e8f0]">
        {title}
      </h2>
      <p class="mt-4 text-[#94a3b8] max-w-2xl mx-auto text-base sm:text-lg leading-relaxed">
        {description}
      </p>
      <div class="mt-8">
        <a
          href={buttonHref}
          class="inline-block px-8 py-3.5 bg-[#f59e0b] text-[#0a1628] font-semibold text-base rounded-lg hover:bg-[#d97706] transition-colors duration-200 shadow-lg shadow-[#f59e0b]/20"
        >
          {buttonText}
        </a>
      </div>
    </div>
  </div>
</section>
