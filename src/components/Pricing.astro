---
interface Props {
  lang: 'en' | 'tr' | 'sk';
}

const { lang } = Astro.props;
const t = await import(`../i18n/${lang}.json`);

const packages = lang === 'tr' ? [
  {
    name: "Web Sitesi Paketi",
    description: "Kurumsal web sitesi, SEO altyapısı dahil",
    price: "€600 – €1.200",
    features: ["5 sayfalık site", "Mobil uyumlu", "SEO optimizasyonu", "İletişim formu", "1 ay destek"],
    bonus: "Ücretsiz 30 dk dijital strateji görüşmesi",
    guarantee: "Beğenmezseniz revizyon ücretsiz",
    risk: "%50 ön ödeme, teslimatta kalan",
    cta: "Teklif Al",
    ctaHref: "/tr/iletisim"
  },
  {
    name: "Otomasyon Paketi",
    description: "İş süreç otomasyonu, n8n kurulumu",
    price: "€800 – €2.000",
    features: ["İhtiyaç analizi", "2-3 otomasyon akışı", "n8n kurulumu", "AI entegrasyonu", "Eğitim"],
    bonus: "1 ay ücretsiz teknik destek",
    guarantee: "Çalışmazsa para iadesi",
    risk: "Önce demo gösterim, beğenirseniz başlayalım",
    cta: "Teklif Al",
    ctaHref: "/tr/iletisim",
    highlighted: true,
    urgency: "Aylık sadece 3 yeni proje"
  },
  {
    name: "Aylık Danışmanlık",
    description: "Sürekli teknik destek ve geliştirme",
    price: "€300 – €900/ay",
    features: ["Aylık teknik danışmanlık", "Öncelikli destek", "Küçük geliştirmeler", "Performans izleme", "Aylık rapor"],
    bonus: "İlk ay acil destek hattı dahil",
    guarantee: "İlk ay memnun kalmazsan ücretsiz çıkış",
    risk: "Aylık iptal serbestisi, sözleşme yok",
    cta: "Görüşme Planla",
    ctaHref: "/tr/iletisim"
  }
] : [
  {
    name: "Website Package",
    description: "Corporate website with SEO infrastructure",
    price: "€600 – €1,200",
    features: ["5-page website", "Mobile responsive", "SEO optimization", "Contact form", "1 month support"],
    bonus: "Free 30-min digital strategy call",
    guarantee: "Free revisions until satisfied",
    risk: "50% upfront, rest on delivery",
    cta: "Get a Quote",
    ctaHref: "/contact"
  },
  {
    name: "Automation Package",
    description: "Business process automation, n8n setup",
    price: "€800 – €2,000",
    features: ["Needs analysis", "2-3 automation workflows", "n8n setup", "AI integration", "Training"],
    bonus: "1 month free technical support",
    guarantee: "Money back if it doesn't work",
    risk: "Demo first, start only if you like it",
    cta: "Get a Quote",
    ctaHref: "/contact",
    highlighted: true,
    urgency: "Only 3 new projects per month"
  },
  {
    name: "Monthly Consulting",
    description: "Ongoing technical support and development",
    price: "€300 – €900/mo",
    features: ["Monthly consulting", "Priority support", "Minor development", "Performance monitoring", "Monthly report"],
    bonus: "First month emergency support included",
    guarantee: "Cancel anytime, no contract",
    risk: "Monthly cancellation, no lock-in",
    cta: "Book a Call",
    ctaHref: "/contact"
  }
];

const sectionTitle = lang === 'tr' ? 'Paketlerim' : lang === 'sk' ? 'Moje balíky' : 'My Packages';
const sectionSubtitle = lang === 'tr' ? 'Net fiyat, net sonuç.' : lang === 'sk' ? 'Jasná cena, jasný výsledok.' : 'Clear pricing, clear results.';
const popularBadge = lang === 'tr' ? 'Popüler' : lang === 'sk' ? 'Populárne' : 'Popular';
---
<section id="pricing" class="py-16 bg-[#192749]">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="section-heading text-center">{sectionTitle}</h2>
    <p class="section-subheading text-center">{sectionSubtitle}</p>

    <div class="grid md:grid-cols-3 gap-8 mt-12">
      {packages.map((pkg) => (
        <div class={`relative bg-[#111d33] rounded-2xl p-8 border transition-all duration-300 hover:-translate-y-1 ${pkg.highlighted ? 'border-[#FFBC42]/50 shadow-lg shadow-[#FFBC42]/10' : 'border-[#1e3a5f] hover:border-[#FFBC42]/30'}`}>
          {pkg.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="bg-[#FFBC42] text-[#0a1628] text-xs font-bold px-4 py-1 rounded-full uppercase tracking-wider">{popularBadge}</span>
            </div>
          )}

          <div class="text-center mb-6">
            <h3 class="text-xl font-bold text-[#e2e8f0] mb-2">{pkg.name}</h3>
            <p class="text-sm text-[#94a3b8] mb-4">{pkg.description}</p>
            <p class="text-3xl font-extrabold text-[#FFBC42]">{pkg.price}</p>
          </div>

          <ul class="space-y-3 mb-6">
            {pkg.features.map((f) => (
              <li class="flex items-center gap-3 text-[#94a3b8]">
                <svg class="w-5 h-5 text-[#FFBC42] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span class="text-sm">{f}</span>
              </li>
            ))}
          </ul>

          <div class="space-y-2 mb-6 border-t border-[#1e3a5f] pt-4">
            <p class="text-xs text-[#4AA9F5] flex items-center gap-2">
              <span>🎁</span> {pkg.bonus}
            </p>
            <p class="text-xs text-green-400 flex items-center gap-2">
              <span>✅</span> {pkg.guarantee}
            </p>
            <p class="text-xs text-[#94a3b8] flex items-center gap-2">
              <span>🛡️</span> {pkg.risk}
            </p>
            {pkg.urgency && (
              <p class="text-xs text-[#FFBC42] flex items-center gap-2">
                <span>⚡</span> {pkg.urgency}
              </p>
            )}
          </div>

          <a
            href={pkg.ctaHref}
            class={`block w-full text-center px-6 py-3 font-semibold rounded-lg transition-colors duration-200 ${pkg.highlighted ? 'bg-[#FFBC42] text-[#0a1628] hover:bg-[#FFBC42]/90 shadow-lg shadow-[#FFBC42]/20' : 'border border-[#FFBC42] text-[#FFBC42] hover:bg-[#FFBC42] hover:text-[#0a1628]'}`}
          >
            {pkg.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
