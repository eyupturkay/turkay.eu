---
interface Props {
  current?: 'en' | 'tr' | 'sk';
}

const { current = 'en' } = Astro.props;

const languages = [
  { code: 'en', label: 'EN', href: '/' },
  { code: 'tr', label: 'TR', href: '/tr/' },
  { code: 'sk', label: 'SK', href: '/sk/' },
];
---
<div class="flex items-center gap-1 text-sm">
  {languages.map((lang, i) => (
    <>
      {i > 0 && <span class="text-[#94a3b8]">|</span>}
      <a
        href={lang.href}
        class:list={[
          'px-1 py-0.5 rounded transition-colors duration-200',
          lang.code === current
            ? 'text-[#f59e0b] font-semibold'
            : 'text-[#94a3b8] hover:text-[#e2e8f0]',
        ]}
      >
        {lang.label}
      </a>
    </>
  ))}
</div>
