---
interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  href: string;
  image?: string;
}

const { title, description, category, tags, href, image } = Astro.props;
---
<a href={href} class="group block bg-[#192749] border-none rounded-xl overflow-hidden shadow-xl transition-all duration-300 hover:scale-[1.02]">
  <!-- Image area -->
  <div class="h-52 overflow-hidden relative">
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-[#0B3C5D] to-[#1D7874]"></div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
    <div class="absolute bottom-0 left-0 p-6 w-full">
      <h3 class="text-xl font-bold text-white">{title}</h3>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6">
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="inline-block px-3 py-1 text-xs font-medium bg-[#FFBC42]/10 text-[#FFBC42] border border-[#FFBC42]/30 rounded-full">
        {category}
      </span>
      {tags.map((tag) => (
        <span class="inline-block px-2 py-0.5 text-xs bg-[#FFBC42]/10 text-[#FFBC42] border border-[#FFBC42]/20 rounded">
          {tag}
        </span>
      ))}
    </div>
    <p class="text-gray-300 text-sm leading-relaxed line-clamp-3">{description}</p>
    <span class="inline-flex items-center mt-4 text-sm font-medium text-[#29A8FF] group-hover:text-[#29A8FF]/70 transition-colors">
      Projeyi Görüntüle
      <svg class="w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
    </span>
  </div>
</a>
