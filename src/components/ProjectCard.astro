---
interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  href: string;
}

const { title, description, category, tags, href } = Astro.props;
---
<a href={href} class="group block bg-[#111d33] border border-[#1e3a5f] rounded-xl p-6 sm:p-8 transition-all duration-300 hover:border-[#f59e0b]/50 hover:shadow-lg hover:shadow-[#f59e0b]/5">
  <span class="inline-block px-3 py-1 text-xs font-medium bg-[#38bdf8]/10 text-[#38bdf8] rounded-full">
    {category}
  </span>
  <h3 class="mt-4 text-lg font-semibold text-[#e2e8f0] group-hover:text-[#f59e0b] transition-colors duration-200">
    {title}
  </h3>
  <p class="mt-2 text-sm text-[#94a3b8] leading-relaxed">
    {description}
  </p>
  <div class="mt-4 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="inline-block px-2 py-0.5 text-xs bg-[#0a1628] text-[#94a3b8] border border-[#1e3a5f] rounded">
        {tag}
      </span>
    ))}
  </div>
</a>
