---
interface Props {
  title: string;
  description: string;
  date: string;
  author: string;
  category: string;
  readTime: string;
  href: string;
}

const { title, description, date, author, category, readTime, href } = Astro.props;
---
<a href={href} class="group block bg-[#111d33] border border-[#1e3a5f] rounded-xl p-6 sm:p-8 transition-all duration-300 hover:border-[#f59e0b]/50 hover:shadow-lg hover:shadow-[#f59e0b]/5">
  <div class="flex items-center gap-3 text-xs text-[#94a3b8]">
    <time datetime={date}>{date}</time>
    <span class="w-1 h-1 rounded-full bg-[#1e3a5f]"></span>
    <span class="inline-block px-2 py-0.5 bg-[#38bdf8]/10 text-[#38bdf8] rounded-full font-medium">
      {category}
    </span>
  </div>
  <h3 class="mt-3 text-lg font-semibold text-[#e2e8f0] group-hover:text-[#f59e0b] transition-colors duration-200 leading-snug">
    {title}
  </h3>
  <p class="mt-2 text-sm text-[#94a3b8] leading-relaxed line-clamp-3">
    {description}
  </p>
  <div class="mt-4 flex items-center justify-between text-xs text-[#94a3b8]">
    <span>{author}</span>
    <span>{readTime}</span>
  </div>
</a>
