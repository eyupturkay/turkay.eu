---
interface Props {
  lang?: 'en' | 'tr' | 'sk';
}

const { lang = 'tr' } = Astro.props;

const steps = lang === 'tr' ? [
  { num: "01", title: "Keşif ve Gereksinim Analizi", description: "İhtiyaçlarınızı derinlemesine anlama, hedeflerinizi belirleme ve proje kapsamını netleştirme aşaması." },
  { num: "02", title: "Araştırma ve Strateji", description: "Pazar analizi, rakip araştırması ve en uygun teknoloji seçimi için kapsamlı stratejik planlama." },
  { num: "03", title: "Tasarım ve Prototipleme", description: "Kullanıcı deneyimi tasarımı, arayüz geliştirme ve işlevsel prototiplerin oluşturulması." },
  { num: "04", title: "Geliştirme ve Entegrasyon", description: "Çevik metodoloji kullanarak iteratif geliştirme ve mevcut sistemlerle sorunsuz entegrasyon." },
  { num: "05", title: "Test ve Optimizasyon", description: "Kapsamlı kalite kontrol, performans testleri ve kullanılabilirlik optimizasyonu." },
  { num: "06", title: "Lansman ve Sürekli İyileştirme", description: "Başarılı bir lansman ve veri odaklı sürekli iyileştirme ile uzun vadeli destek." },
] : [
  { num: "01", title: "Discovery & Analysis", description: "Understanding your needs, defining goals and clarifying project scope." },
  { num: "02", title: "Research & Strategy", description: "Market analysis, competitor research and strategic technology selection." },
  { num: "03", title: "Design & Prototyping", description: "UX design, interface development and functional prototyping." },
  { num: "04", title: "Development & Integration", description: "Iterative agile development and seamless integration with existing systems." },
  { num: "05", title: "Testing & Optimization", description: "Comprehensive QA, performance testing and usability optimization." },
  { num: "06", title: "Launch & Continuous Improvement", description: "Successful launch and data-driven continuous improvement with long-term support." },
];
---
<section class="py-16 blueprint-bg">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="section-heading text-center">{lang === 'tr' ? 'Çalışma Metodolojim' : 'My Methodology'}</h2>
    <p class="section-subheading text-center">
      {lang === 'tr' ? 'Projelerinizi başarıyla hayata geçirmek için izlediğim kanıtlanmış süreç' : 'Proven process I follow to successfully deliver your projects'}
    </p>

    <div class="mt-12 relative">
      <!-- Connecting line (desktop) -->
      <div class="absolute left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-[#4AA9F5] to-[#FFBC42] -translate-x-1/2 hidden md:block"></div>

      <div class="space-y-8 md:space-y-0">
        {steps.map((step, i) => (
          <div class={`flex flex-col md:flex-row items-center ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} gap-8 relative mb-8`}>
            <!-- Center dot -->
            <div class="absolute left-1/2 -translate-x-1/2 w-10 h-10 bg-[#1A2B50] border-2 border-[#FFBC42] rounded-full z-10 hidden md:flex items-center justify-center">
              <div class="w-4 h-4 bg-[#FFBC42] rounded-full"></div>
            </div>

            <!-- Content -->
            <div class={`md:w-5/12 ${i % 2 === 0 ? 'md:mr-auto md:text-right' : 'md:ml-auto md:text-left'}`}>
              <div class="bg-[#1A2B50] p-6 rounded-xl shadow-lg border border-[#1e3a5f]/30">
                <div class={`flex items-center gap-3 mb-3 ${i % 2 === 0 ? 'md:justify-end' : ''}`}>
                  <span class="text-2xl font-extrabold text-[#FFBC42]">{step.num}</span>
                  <h3 class="text-lg font-bold text-[#e2e8f0]">{step.title}</h3>
                </div>
                <p class="text-[#94a3b8]">{step.description}</p>
              </div>
            </div>

            <!-- Spacer -->
            <div class="md:w-5/12"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
