---
interface Props {
  title?: string;
  subtitle?: string;
}

const { title = "Teknoloji Ortaklarımız", subtitle = "Lider teknoloji sağlayıcılarıyla işbirliği yaparak en yenilikçi çözümleri sunuyorum" } = Astro.props;

const partners = [
  { name: "Microsoft", color: "#00A4EF" },
  { name: "AWS", color: "#FF9900" },
  { name: "Google Cloud", color: "#4285F4" },
  { name: "IBM", color: "#0F62FE" },
  { name: "Oracle", color: "#F80000" },
  { name: "MongoDB", color: "#47A248" },
  { name: "Docker", color: "#2496ED" },
  { name: "Kubernetes", color: "#326CE5" },
];
---
<section class="py-16 bg-[#1A2B50]">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="section-heading text-center">{title}</h2>
    <p class="section-subheading text-center">{subtitle}</p>

    <div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-6">
      {partners.map((partner, i) => (
        <div
          class="bg-white/5 backdrop-blur-sm rounded-xl p-6 flex items-center justify-center hover:bg-white/10 transition-all duration-300 animate-fadeInUp"
          style={`animation-delay: ${i * 100}ms; animation-fill-mode: forwards;`}
        >
          <span class="text-lg font-bold tracking-wide" style={`color: ${partner.color};`}>
            {partner.name}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
