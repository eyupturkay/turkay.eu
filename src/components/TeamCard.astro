---
interface Props {
  name: string;
  role: string;
  bio: string;
  linkedin?: string;
}

const { name, role, bio, linkedin } = Astro.props;
const initials = name.split(' ').map((n) => n[0]).join('').slice(0, 2).toUpperCase();
---
<div class="bg-[#111d33] border border-[#1e3a5f] rounded-xl p-6 sm:p-8 text-center">
  <!-- Avatar placeholder -->
  <div class="mx-auto w-20 h-20 rounded-full bg-gradient-to-br from-[#f59e0b] to-[#38bdf8] flex items-center justify-center text-2xl font-bold text-[#0a1628]">
    {initials}
  </div>

  <h3 class="mt-4 text-lg font-semibold text-[#e2e8f0]">
    {name}
  </h3>
  <p class="text-sm text-[#f59e0b] font-medium">
    {role}
  </p>
  <p class="mt-3 text-sm text-[#94a3b8] leading-relaxed">
    {bio}
  </p>

  {linkedin && (
    <a
      href={linkedin}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 mt-4 text-sm text-[#38bdf8] hover:text-[#f59e0b] transition-colors duration-200"
      aria-label={`${name} on LinkedIn`}
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      LinkedIn
    </a>
  )}
</div>
