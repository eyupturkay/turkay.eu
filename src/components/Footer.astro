---
interface Props {
  lang: 'en' | 'tr' | 'sk';
}

const { lang } = Astro.props;

const t = await import(`../i18n/${lang}.json`);

const quickLinks = {
  en: [
    { href: '/', label: t.nav.home },
    { href: '/services', label: t.nav.services },
    { href: '/projects', label: t.nav.projects },
    { href: '/blog', label: t.nav.blog },
    { href: '/contact', label: t.nav.contact },
  ],
  tr: [
    { href: '/tr/', label: t.nav.home },
    { href: '/tr/hizmetlerimiz', label: t.nav.services },
    { href: '/tr/projelerimiz', label: t.nav.projects },
    { href: '/tr/yazilar', label: t.nav.blog },
    { href: '/tr/iletisim', label: t.nav.contact },
  ],
  sk: [
    { href: '/sk/', label: t.nav.home },
    { href: '/sk/sluzby', label: t.nav.services },
    { href: '/sk/projekty', label: t.nav.projects },
    { href: '/sk/blog', label: t.nav.blog },
    { href: '/sk/kontakt', label: t.nav.contact },
  ],
};

const links = quickLinks[lang];

const bratislava = {
  address: 'SKY PARK Offices, Bottova 7939/2A, 811 09 Bratislava',
  phone: '+421 915 455 756',
};

const companyDesc = lang === 'tr'
  ? 'Freelance yazılım danışmanı olarak yapay zeka, bulut ve yazılım çözümleri sunuyorum. 10+ yıllık deneyimimle dijital dönüşümünüzü hızlandırıyorum.'
  : lang === 'sk'
  ? 'Ako freelance softvérový konzultant ponúkam riešenia AI, cloud a softvéru.'
  : 'As a freelance software consultant, I deliver AI, cloud and software solutions. 10+ years of experience accelerating digital transformation.';

const currentYear = new Date().getFullYear();
---
<footer class="bg-[#192749] border-t border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Logo & description -->
      <div class="lg:col-span-1">
        <a href={lang === 'en' ? '/' : `/${lang}/`} class="inline-flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-8 h-8 bg-[#FFBC42] rounded-lg text-[#0a1628] font-extrabold text-sm">T</span>
          <span class="text-xl font-extrabold"><span class="text-[#FFBC42]">TURKAY</span><span class="text-[#29A8FF]">.EU</span></span>
        </a>
        <p class="mt-3 text-sm text-white/80 leading-relaxed">
          {companyDesc}
        </p>
        <!-- Social links -->
        <div class="flex space-x-4 mt-4">
          <a href="https://linkedin.com/in/eyupturkay" target="_blank" rel="noopener" class="text-white/60 hover:text-[#FFBC42] transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://github.com/eyupturkay" target="_blank" rel="noopener" class="text-white/60 hover:text-[#FFBC42] transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold text-white/90 uppercase tracking-wider mb-4">
          {t.footer.quickLinks}
        </h3>
        <ul class="space-y-2">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/70 hover:text-[#FFBC42] transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact - Only Bratislava (freelancer, no Istanbul) -->
      <div>
        <h3 class="text-sm font-semibold text-white/90 uppercase tracking-wider mb-4">
          {t.footer.contact}
        </h3>
        <div class="space-y-4 text-sm text-white/80">
          <div>
            <p class="font-medium text-white/90 mb-1">Bratislava, Slovakia</p>
            <p>{bratislava.address}</p>
            <a href={`tel:${bratislava.phone.replace(/[\s()]/g, '')}`} class="hover:text-[#FFBC42] transition-colors duration-200">
              {bratislava.phone}
            </a>
          </div>
          <div>
            <a href="mailto:info@turkay.eu" class="hover:text-[#FFBC42] transition-colors duration-200">
              info@turkay.eu
            </a>
          </div>
        </div>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="text-sm font-semibold text-white/90 uppercase tracking-wider mb-4">
          {t.footer.newsletter}
        </h3>
        <form class="flex flex-col gap-2" onsubmit="return false;">
          <input
            type="email"
            placeholder="email@example.com"
            class="w-full px-3 py-2 bg-[#0a1628] border border-white/10 rounded text-sm text-white placeholder-white/50 focus:outline-none focus:border-[#FFBC42] transition-colors duration-200"
          />
          <button
            type="submit"
            class="px-4 py-2 bg-[#FFBC42] text-[#0a1628] font-semibold text-sm rounded hover:bg-[#FFBC42]/90 transition-colors duration-200"
          >
            {t.footer.subscribe}
          </button>
        </form>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-10 pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-center text-sm text-white/60">
      <span>&copy; {currentYear} TURKAY.EU Digital Solutions. {t.footer.rights}</span>
      <div class="flex space-x-6 mt-4 md:mt-0">
        <a href="#" class="hover:text-[#FFBC42] transition-colors">Privacy</a>
        <a href="#" class="hover:text-[#FFBC42] transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
