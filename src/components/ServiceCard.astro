---
interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
}

const { title, description, icon, href } = Astro.props;
---
<a href={href} class="group block bg-[#111d33] border border-[#1e3a5f] rounded-xl p-6 sm:p-8 transition-all duration-300 hover:border-[#f59e0b]/50 hover:shadow-lg hover:shadow-[#f59e0b]/5">
  <div class="text-3xl mb-4" set:html={icon} />
  <h3 class="text-lg font-semibold text-[#e2e8f0] group-hover:text-[#f59e0b] transition-colors duration-200">
    {title}
  </h3>
  <p class="mt-2 text-sm text-[#94a3b8] leading-relaxed">
    {description}
  </p>
  <span class="inline-block mt-4 text-sm font-medium text-[#f59e0b] group-hover:translate-x-1 transition-transform duration-200">
    &rarr;
  </span>
</a>
